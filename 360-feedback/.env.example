# Slack App credentials
# Create your app at https://api.slack.com/apps
# Enable Socket Mode and generate an App-Level Token with connections:write scope
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Anthropic API key for theme summarization
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key

# Optional: path to SQLite database file (defaults to ./360_feedback.db)
# DB_PATH=./360_feedback.db

# Optional: Day of week for weekly nudges (0=Monday ... 6=Sunday, default: 0)
# NUDGE_DAY=0

# Optional: Time for weekly nudges in 24h format (default: 09:00)
# NUDGE_TIME=09:00
